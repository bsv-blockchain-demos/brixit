{
  "name": "brixit-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "psql $DATABASE_URL -f prisma/seed.sql",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset"
  },
  "dependencies": {
    "@bsv/sdk": "^1.10.3",
    "@prisma/client": "^6.4.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jose": "^5.9.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.5",
    "prisma": "^6.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3"
  }
}
