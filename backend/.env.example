# Server
PORT=3001
NODE_ENV=development

# Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/brixit

# JWT — use a strong random secret in production
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Wallet relay — both must be reachable by the mobile device (use LAN IP in dev)
# In production use wss:// / https:// matching your domain
RELAY_URL=ws://localhost:3001
# Backend HTTP URL embedded in QR codes — mobile calls ${ORIGIN}/api/session/:id to resolve the relay
# Set to your LAN IP in dev: http://192.168.x.x:3001
ORIGIN=http://localhost:3001

# BSV wallet auth
# SERVER_PRIVATE_KEY: private key for the server-side ProtoWallet
#   - issues Mycelia/Brixit Identity certificates (certifier = this key's public key)
#   - verifies login nonces
# The corresponding public key must be set as VITE_SERVER_PUBLIC_KEY in the frontend .env
SERVER_PRIVATE_KEY=your_backend_wallet_private_key

# Mycelia certificate type — must match VITE_CERT_TYPE in the frontend .env
CERT_TYPE=Brixit Identity

# Email — OTP verification during account creation
# Leave SMTP_HOST unset to log OTPs to the console (development mode)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM=noreply@brixit.app

# Submissions — user ID used for auto-verification
AUTO_VERIFY_USER_ID=

# GeoNames reverse-geocoding (free account at geonames.org)
GEONAMES_USERNAME=your_geonames_username

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
