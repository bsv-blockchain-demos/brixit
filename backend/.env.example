# Server
PORT=3001
NODE_ENV=development

# Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/brixit

# JWT — use a strong random secret in production
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Wallet relay — WebSocket URL embedded in QR codes, must be reachable by the mobile device
# In production use wss:// matching your domain: wss://api.yourapp.com
RELAY_URL=ws://localhost:3001

# BSV wallet auth
# COMMONSOURCE_SERVER_KEY: public key of the CommonSource certifier
COMMONSOURCE_SERVER_KEY=your_commonsource_server_public_key
# BACKEND_PRIVATE_KEY: private key for the server-side ProtoWallet used to verify login nonces
# The corresponding public key must be set as VITE_BACKEND_PUBLIC_KEY in the frontend .env
BACKEND_PRIVATE_KEY=your_backend_wallet_private_key

# Submissions — user ID used for auto-verification
AUTO_VERIFY_USER_ID=

# GeoNames reverse-geocoding (free account at geonames.org)
GEONAMES_USERNAME=your_geonames_username

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
