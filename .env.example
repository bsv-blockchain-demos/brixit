# Backend API
VITE_API_URL=http://localhost:3001

# Mapbox (either name is accepted)
VITE_MAPBOX_TOKEN=your_mapbox_public_token

# CommonSource / BSV wallet auth
VITE_COMMONSOURCE_SERVER_KEY=your_commonsource_server_public_key
VITE_CERT_TYPE=CommonSource identity
VITE_EXTERNAL_ONBOARDING_URL=https://commonsource.online/onboard

# Backend wallet identity — must match BACKEND_PRIVATE_KEY in backend/.env
VITE_SERVER_PUBLIC_KEY=your_backend_wallet_public_key
