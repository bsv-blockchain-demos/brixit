# Backend API
VITE_API_URL=http://localhost:3001

# Mapbox (either name is accepted)
VITE_MAPBOX_TOKEN=your_mapbox_public_token

# BSV wallet auth
# VITE_SERVER_PUBLIC_KEY: backend identity public key — must match SERVER_PRIVATE_KEY in backend/.env
# This key is also the Mycelia certificate certifier key
VITE_SERVER_PUBLIC_KEY=your_backend_wallet_public_key

# Mycelia certificate type — must match CERT_TYPE in backend/.env
VITE_CERT_TYPE=Brixit Identity

# Mycelia ID (V2 parent identity) — second accepted login cert
VITE_MYCELIA_CERTIFIER=027e1a4071b3b210166d0546299936c7abde87abc72fd61e0870babf0d0cea5756
VITE_MYCELIA_CERT_TYPE=Mycelia Identity
